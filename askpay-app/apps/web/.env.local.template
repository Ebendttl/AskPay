# AskPay — Environment Variables
# Copy this to .env.local and fill in the values.
# NEVER commit .env.local to git.

# ── Blockchain ──────────────────────────────────────────────────────────────

# Deployed contract address on Celo Sepolia (Phase 2 — fill after deploy)
NEXT_PUBLIC_CONTRACT_ADDRESS_SEPOLIA=

# Deployed contract address on Celo Mainnet (Phase 6 — fill after mainnet deploy)
NEXT_PUBLIC_CONTRACT_ADDRESS_MAINNET=

# USDm token address on Celo Mainnet (18 decimals)
# Verify current address via Celoscan before relying on this.
NEXT_PUBLIC_USDM_ADDRESS_MAINNET=0x765DE816845861e75A25fCA122bb6898B8B1282a

# USDm token address on Celo Sepolia
NEXT_PUBLIC_USDM_ADDRESS_SEPOLIA=

# ── RainbowKit / WalletConnect ───────────────────────────────────────────────

# Get a free project ID at https://cloud.walletconnect.com
# Required for desktop/non-MiniPay wallet connections.
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id_here

# ── LLM Backend ─────────────────────────────────────────────────────────────

# API key for the LLM provider (Groq or Gemini) — NEVER expose this client-side.
# Used only in the Next.js API route (/api/ask).
LLM_API_KEY=

# Provider identifier — "groq" or "gemini"
LLM_API_PROVIDER=groq

# ── Contract Deployment (Hardhat) ────────────────────────────────────────────
# These are NOT prefixed NEXT_PUBLIC_ — they are server/CI-only secrets.
# Set them in apps/contracts/.env (see apps/contracts/.env.example for the template).
# PRIVATE_KEY=         (deployer wallet private key — never commit)
# ETHERSCAN_API_KEY=   (Celoscan/Etherscan API key for contract verification)

# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Maximum number of requests allowed per IP per window (default: 10)
RATE_LIMIT_MAX_REQUESTS=10

# Sliding window duration in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# ── Admin API ─────────────────────────────────────────────────────────────────

# Secret used to authenticate requests to /api/admin/request-log.
# Set to a long random string — e.g. `openssl rand -hex 32`
# If unset, the admin route returns 503.
ADMIN_SECRET=
